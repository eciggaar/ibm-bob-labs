---
// src/pages/index.astro
import { getCollection } from 'astro:content';

// Grab all markdown pages from the docs collection
const docs = (await getCollection('docs'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Get lab series count
const allLabs = await getCollection('labs');
const labSeriesCount = new Set(allLabs.map(lab => lab.data.lab_series)).size;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Documentation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-white font-sans antialiased">

    <!-- Hero -->
    <header class="border-b border-slate-200 bg-gradient-to-b from-brand-50 to-white px-6 py-16 text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-brand-500">Learning Resources</p>
      <h1 class="text-4xl font-bold text-slate-900 sm:text-5xl">IBM Bob Learning Labs</h1>
      <p class="mx-auto mt-4 max-w-lg text-lg text-slate-500">
        Master AI-assisted development with comprehensive hands-on tutorials
      </p>
    </header>

    <!-- What You Will Learn -->
    <main class="mx-auto max-w-4xl px-6 py-12">
      <section class="mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-6">Available Labs</h2>
        <p class="text-lg text-slate-600 mb-8">
          Choose from our comprehensive hands-on lab series:
        </p>

        <div class="grid gap-6 sm:grid-cols-2">
          <!-- Bob Intro Lab -->
          <a
            href={`${import.meta.env.BASE_URL}/labs/bob-intro`}
            class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-brand-500">
                Lab Series
              </span>
              <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                2-3 hours
              </span>
            </div>
            <h2 class="text-xl font-semibold text-slate-900 group-hover:text-brand-700 transition-colors">
              Bob Intro Lab
            </h2>
            <p class="mt-2 text-sm text-slate-500 line-clamp-2">Get started with IBM Bob and the Galaxium Travels demo app by learning the tutorial flow, setup requirements, and application architecture.</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-xs text-slate-400">
                7 sections
              </span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-brand-600">
                Start lab
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </a>

          <!-- Bob as Documentalist -->
          <a
            href={`${import.meta.env.BASE_URL}/labs/bob-as-documentalist`}
            class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-brand-500">
                Lab Series
              </span>
              <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                30 minutes
              </span>
            </div>
            <h2 class="text-xl font-semibold text-slate-900 group-hover:text-brand-700 transition-colors">
              Meet Bob, your AI documentalist
            </h2>
            <p class="mt-2 text-sm text-slate-500 line-clamp-2">Explore the document class model, relationships, and cleaning recommendations. Learn to inventory 91 document classes and identify historical debt.</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-xs text-slate-400">
                5 sections
              </span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-brand-600">
                Start lab
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </a>

          <!-- Generate Sample Content -->
          <a
            href={`${import.meta.env.BASE_URL}/labs/generate-sample-content`}
            class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-brand-500">
                Lab Series
              </span>
              <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                45 minutes
              </span>
            </div>
            <h2 class="text-xl font-semibold text-slate-900 group-hover:text-brand-700 transition-colors">
              Feeding Bob: generate sample content
            </h2>
            <p class="mt-2 text-sm text-slate-500 line-clamp-2">Create realistic HR documents to populate the repository. Generate and upload 55 documents with proper metadata.</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-xs text-slate-400">
                6 sections
              </span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-brand-600">
                Start lab
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </a>

          <!-- Review and Reclassify -->
          <a
            href={`${import.meta.env.BASE_URL}/labs/review-and-reclassify`}
            class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-brand-500">
                Lab Series
              </span>
              <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                45 minutes
              </span>
            </div>
            <h2 class="text-xl font-semibold text-slate-900 group-hover:text-brand-700 transition-colors">
              Bob the Classifier: Review & Reclassify
            </h2>
            <p class="mt-2 text-sm text-slate-500 line-clamp-2">Use AI to detect and fix misclassified documents. Learn the reclassification workflow and create governance health reports.</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-xs text-slate-400">
                6 sections
              </span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-brand-600">
                Start lab
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </a>
        </div>
      </section>

      <!-- Why These Labs -->
      <section class="rounded-xl border border-slate-200 bg-slate-50 p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Why These Labs?</h2>
        <p class="text-base text-slate-600 leading-relaxed">
          These hands-on tutorials provide practical experience with IBM Bob across different use cases—from software development to enterprise content management. Each lab uses real-world scenarios and production-like environments to build applicable skills.
        </p>
      </section>

    </main>

    </main>

  </body>
</html>
