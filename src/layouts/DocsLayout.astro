---
// src/layouts/DocsLayout.astro
import '../styles/code-blocks.css';

export interface Props {
  title: string;
  description?: string;
  // All pages passed in so we can build the sidebar
  allPages?: { title: string; slug: string; section?: string }[];
  currentSlug?: string;
}

const { title, description = '', allPages = [], currentSlug = '' } = Astro.props;

// Group pages by optional section frontmatter
const sections = allPages.reduce<Record<string, typeof allPages>>((acc, page) => {
  const key = page.section ?? 'General';
  (acc[key] ??= []).push(page);
  return acc;
}, {});
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Docs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="h-full bg-white text-slate-900 antialiased">

    <!-- Top nav bar -->
    <header class="fixed top-0 left-0 right-0 z-30 h-14 border-b border-slate-200 bg-white/90 backdrop-blur-sm flex items-center px-6 gap-4">
      <a href="/" class="text-base font-semibold text-brand-700 tracking-tight hover:text-brand-600 transition-colors">
        📄 Docs
      </a>
      <span class="flex-1" />
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 hover:text-slate-800 transition-colors"
      >
        GitHub ↗
      </a>
    </header>

    <div class="flex h-full pt-14">

      <!-- Sidebar -->
      <aside
        id="sidebar"
        class="fixed top-14 left-0 bottom-0 z-20 w-64 overflow-y-auto border-r border-slate-200 bg-slate-50 px-4 py-6 hidden lg:block"
      >
        {Object.entries(sections).map(([section, pages]) => (
          <div class="mb-6">
            <p class="mb-2 px-2 text-xs font-semibold uppercase tracking-wider text-slate-400">
              {section}
            </p>
            <ul class="space-y-0.5">
              {pages.map((page) => (
                <li>
                  <a
                    href={`/${page.slug}`}
                    class={`block rounded-md px-3 py-1.5 text-sm transition-colors ${
                      currentSlug === page.slug
                        ? 'bg-brand-100 font-medium text-brand-700'
                        : 'text-slate-600 hover:bg-slate-200 hover:text-slate-900'
                    }`}
                  >
                    {page.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <!-- Mobile sidebar toggle -->
      <button
        id="sidebar-toggle"
        class="lg:hidden fixed bottom-6 right-6 z-40 rounded-full bg-brand-600 p-3 text-white shadow-lg hover:bg-brand-700 transition-colors"
        aria-label="Toggle navigation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Main content -->
      <main class="flex-1 lg:ml-64 min-w-0">
        <div class="mx-auto max-w-3xl px-6 py-10">
          <article class="prose prose-slate prose-headings:font-semibold prose-a:text-brand-600 prose-code:font-mono prose-pre:bg-slate-900 max-w-none">
            <slot />
          </article>

          <!-- Page footer nav -->
          <div class="mt-12 flex items-center justify-between border-t border-slate-200 pt-6 text-sm text-slate-500">
            <a href="/" class="hover:text-brand-600 transition-colors">← All docs</a>
            <span class="text-xs text-slate-400">Last updated: {new Date().toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </div>
        </div>
      </main>

    </div>

    <script>
      import { initCopyButtons } from '../utils/copyButton.js';

      const toggle = document.getElementById('sidebar-toggle');
      const sidebar = document.getElementById('sidebar');
      toggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('hidden');
        sidebar?.classList.toggle('block');
      });

      // Initialize copy buttons for code blocks
      initCopyButtons();
    </script>

  </body>
</html>
